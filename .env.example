# Variables de entorno requeridas para el proyecto
# Copia este archivo a .env.local y configura los valores

# API Secret Key - INVENTA una clave segura para proteger tus APIs
# Esta NO es de Shopify, es para tu aplicación (puedes usar cualquier texto seguro)
API_SECRET_KEY=tu_clave_inventada_super_secreta_aqui

# Frontend API Key - La misma clave pero con prefijo VITE_ para el frontend
VITE_API_SECRET_KEY=tu_clave_inventada_super_secreta_aqui

# URLs de las APIs
VITE_API_BASE_URL=http://localhost:3000

# Configuración de Shopify - USA TUS DATOS REALES DE SHOPIFY
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_real_shopify_token_here
SHOPIFY_API_VERSION=2024-07les de entorno requeridas para el proyecto
# Copia este archivo a .env.local y configura los valores

# API Secret Key - Usa una clave segura y única
VITE_API_SECRET_KEY=your_secure_api_key_here

# URL base de la API
VITE_API_BASE_URL=http://localhost:3000
